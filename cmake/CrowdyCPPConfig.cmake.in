@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads)
if(NOT TARGET CURL::libcurl)
  find_dependency(CURL)
endif()
if(NOT TARGET OpenSSL::Crypto)
  find_dependency(OpenSSL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CrowdyCPPTargets.cmake")

# Convenience alias: link CrowdyCPP::crowdy for the full SDK.
check_required_components(CrowdyCPP)
